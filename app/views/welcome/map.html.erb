<div id="map" style="width: 70%; height: 880px; margin: 0 auto;"></div>

<script>
  function initMap() {
    const map = new google.maps.Map(document.getElementById("map"), {
      center: { lat: 22.4198, lng: 114.2068 },
      zoom: 16,
      minZoom: 16,
      gestureHandling: "auto",
      keyboardShortcuts: false,
      restriction: {
        latLngBounds: {
          north: 22.427399116455383,
          south: 22.412482562008687,
          west: 114.19803399534455,
          east: 114.21494387024956,
        },
        strictBounds: true,
      },
    });

    // Define your pins here
    const locations = [
{
        lat: 22.420089834513423,
        lng: 114.2072099614738,
        title: "Sir Run Run Shaw Hall",
        url: "/sirrunrunshawhall",
        image_url: "<%= asset_path('sir_run_run.jpg') %>"
      },
      {
        lat: 22.42090899131629, 
        lng: 114.20930435032216,
        title: "NA Gym",
        url: "/nagym",
        image_url: "<%= asset_path('na_gym.jpg') %>"
      },
      {
        lat: 22.420960312540984, 
        lng: 114.20567848673426,
        title: "UC Gym",
        url: "/ucgym",
        image_url: "<%= asset_path('uc_gym.jpg') %>"
      },
      {
        lat: 22.41493476795026, 
        lng: 114.20880499854452,
        title: "Lingnan Stadium",
        url: "/lingnanstadium",
        image_url: "<%= asset_path('lingnan_stadium.jpg') %>"
      },
      {
        lat: 22.418781207707248,
        lng: 114.21198997917793,
        title: "University Sports Centre",
        url: "/usportscentre",
        image_url: "<%= asset_path('u_sports_centre.jpg') %>"
      },
      {
        lat: 22.422362888628257,
        lng: 114.2016351058803,
        title: "Shaw College lecture Theatre",
        url: "/shawtheatre",
        image_url: "<%= asset_path('shaw_theatre.jpg') %>"
      },
    ];

    // Create an info window (shared across all markers)
    const infoWindow = new google.maps.InfoWindow();

    // Loop through and create markers
    locations.forEach(location => {
      const marker = new google.maps.Marker({
        position: { lat: location.lat, lng: location.lng },
        map: map,
        title: location.title,
      });

      // Click marker → show info window with a link
      marker.addListener("click", () => {
        const contentString = `
          <div style="padding: 5px; width: 200px;">
            ${location.image_url ? 
              `<img src="${location.image_url}" style="width:100%; height:auto; border-radius:8px; margin-bottom:8px;">` : 
              ''
            }
            <div style="font-weight: bold; font-size: 14px;">${location.title}</div>
            <a href="${location.url}" style="color: #4285F4; text-decoration: none; font-size: 12px;">Go to page →</a>
          </div>
        `;
        
        infoWindow.setContent(contentString);
        infoWindow.open(map, marker);
      });
    });
  }
</script>

<script
  src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.application.credentials.google_maps_api_key %>&callback=initMap"
  defer>
</script>