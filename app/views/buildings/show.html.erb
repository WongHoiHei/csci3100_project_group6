<div style="padding: 50px; text-align: center; font-family: sans-serif;">
  <p style="color: #666; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0;">Building Details</p>
  
  <h1 style="font-size: 2.5rem; margin-top: 10px;"><%= @official_name %></h1>
  
  <hr style="width: 50px; border: 2px solid #4285F4; margin: 30px auto;">

  <div style="max-width: 600px; margin: 0 auto; text-align: left;">


    <h3 style="margin-top: 30px;">Choose Venue</h3>
    <% if @venues.any? %>
      <% @venues.each do |venue| %>
        <details style="margin-bottom: 12px; border: 1px solid #ddd; border-radius: 8px; padding: 10px;">
          <summary style="cursor: pointer; font-weight: bold;"><%= venue.name %></summary>
          <% if venue.time_slots.any? %>
            <ul style="margin-top: 10px;">
              <% venue.time_slots.order(:start_time).each do |slot| %>
                <li style="margin-bottom: 6px;">
                  <%= slot.start_time.strftime("%H:%M") %> - <%= slot.end_time.strftime("%H:%M") %>
                  <%= link_to 'Book', "/bookings/new?bookable_id=#{venue.id}&bookable_type=Venue&time_slot_id=#{slot.id}", style: "margin-left: 8px;" %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p style="margin-top: 10px; color: #666;">No available time slots for this venue.</p>
          <% end %>
        </details>
      <% end %>
    <% else %>
      <p style="color: #666;">No venues found for this location.</p>
    <% end %>
  </div>

  <div style="margin-top: 40px;">
    <%= link_to "← Back to Map", "/map", style: "color: #666; text-decoration: none;" %>
  </div>
</div>