%h1 New Booking

%p You are booking: #{@bookable_type} - #{@bookable_id}

%p Time Slot: git status
-if @time_slot_id.present?
  -time_slot =TimeSlot.find(@time_slot_id)
  %p Time Slot: #{time_slot.start_time.strftime("%H:%M")} - #{time_slot.end_time.strftime("%H:%M")}
-else
  %p Time Slot: Please select a time slot
  

= form_with model: @booking do |f|
  = f.hidden_field :bookable_id, value: @bookable_id
  = f.hidden_field :bookable_type, value: @bookable_type
  = f.hidden_field :time_slot_id, value: @time_slot_id
  = f.submit 'Confirm Booking'