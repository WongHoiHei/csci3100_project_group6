<style>
  html, body {
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .full-screen-map-page {
    position: relative;
    width: 100vw;
    height: 100vh;
  }

  #map {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .map-overlay-header {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 1000;
    background: white;
    padding: 0;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    width: 380px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow: hidden;
  }

  .back-to-main-btn {
    display: block;
    padding: 12px;
    background: #166534;
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    transition: background 0.2s ease;
  }

  .back-to-main-btn:hover {
    background: #14532d;
  }

  .overlay-content {
    padding: 15px 20px;
  }

  .overlay-title {
    font-weight: 800;
    font-size: 18px;
    margin-bottom: 12px;
    white-space: nowrap;
    color: #14532d;
    text-transform: capitalize;
  }

  .search-container {
    display: flex;
    gap: 8px;
    margin-bottom: 5px;
  }

  #venue-search {
    flex-grow: 1;
    padding: 8px 12px;
    border: 1px solid #b9d6af;
    border-radius: 6px;
    outline: none;
  }

  #search-btn {
    padding: 8px 16px;
    background: #166534;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 700;
  }

  .user-info-row {
    margin-top: 10px;
    border-top: 1px solid #eee;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    background: #f9fafb;
  }

  .user-display-name {
    font-weight: 700;
    font-size: 14px;
    color: #14532d;
  }

  .logout-link {
  background: #d1fae5;
  color: #065f46;
  text-decoration: none;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 4px;
  transition: background 0.2s ease;
  }

  .logout-link:hover {
  background: #b7f2d7;
  color: #064e3b;
  }
</style>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div class="full-screen-map-page">
  <div class="map-overlay-header">
    <%= link_to "← Back to Main", main_path, class: "back-to-main-btn" %>
    
    <div class="overlay-content">
      <div class="overlay-title">CUHK Facilities Booking</div>
      <div class="search-container">
        <input type="text" id="venue-search" placeholder="Search venue..."> 
        <button id="search-btn">Search</button>
      </div>
    </div>

    <% if current_user %>
      <div class="user-info-row">
        <span class="user-display-name"><%= current_user.name %></span>
        <%= link_to "Log out", root_path, data: { turbo_method: :delete }, class: "logout-link" %>
      </div>
    <% end %>
  </div>
  <div id="map"></div>
</div>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>

<script>
  function initMap() {
    const map = L.map("map", {
      minZoom: 10,
      zoomControl: true
    }).setView([22.4198, 114.2068], 17);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors"
    }).addTo(map);

    const locations = <%= raw(@map_locations.to_json) %>;
    const markers = [];

    locations.forEach(location => {
      const marker = L.marker([location.lat, location.lng]).addTo(map);
      marker.customData = location;
      marker.bindPopup(buildPopupContent(location));

      markers.push({
        marker: marker,
        title: location.title.toLowerCase()
      });
    });

    function buildPopupContent(data) {
      return `
        <div style="padding: 5px; width: 200px;">
          ${data.image_url ? `<img src="${data.image_url}" style="width:100%; height:auto; border-radius:8px; margin-bottom:8px;">` : ''}
          <div style="font-weight: bold; font-size: 14px;">${data.title}</div>
          <div style="font-size: 12px; margin: 4px 0 8px; color: #374151;">Venues: ${data.venue_count}</div>
          <a href="/buildings/${data.slug}" style="color: #4285F4; text-decoration: none; font-size: 12px; font-weight: bold;">Go to page →</a>
        </div>
      `;
    }

    const searchInput = document.getElementById("venue-search");
    const searchBtn = document.getElementById("search-btn");

    function performSearch() {
      const query = searchInput.value.toLowerCase().trim();
      if (!query) return;

      const match = markers.find(m => m.title.includes(query));

      if (match) {
        map.setView(match.marker.getLatLng(), 17, { animate: true });
        match.marker.openPopup();
      } else {
        alert("Venue not found.");
      }
    }

    searchBtn.addEventListener("click", performSearch);
    searchInput.addEventListener("keypress", (e) => {
      if (e.key === "Enter") performSearch();
    });
  }

  document.addEventListener("DOMContentLoaded", initMap);
</script>