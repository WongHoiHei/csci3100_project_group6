<style>
  html, body {
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .full-screen-map-page {
    position: relative;
    width: 100vw;
    height: 100vh;
  }

  #map {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .map-overlay-header {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 1000;
    background: white;
    padding: 0;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    width: 380px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow: hidden;
  }

  .back-to-main-btn {
    display: block;
    padding: 12px;
    background: #166534;
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    transition: background 0.2s ease;
    box-sizing: border-box;
  }

  .back-to-main-btn:hover {
    background: #14532d;
  }

  .overlay-content {
    padding: 15px 20px;
  }

  .overlay-title {
    font-weight: 800;
    font-size: 18px;
    margin-bottom: 12px;
    white-space: nowrap;
    color: #14532d;
    text-transform: capitalize;
  }

  .search-container {
    display: flex;
    gap: 8px;
    margin-bottom: 5px;
  }

  #venue-search {
    flex-grow: 1;
    padding: 8px 12px;
    border: 1px solid #b9d6af;
    border-radius: 6px;
    outline: none;
  }

  #search-btn {
    padding: 8px 16px;
    background: #166534;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 700;
  }

  .user-info-row {
    margin-top: 10px;
    border-top: 1px solid #eee;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    background: #f9fafb;
  }

  .user-display-name {
    font-weight: 700;
    font-size: 14px;
    color: #14532d;
  }

  .logout-link {
  background: #d1fae5;
  color: #065f46;
  text-decoration: none;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 4px;
  transition: background 0.2s ease;
  }

  .logout-link:hover {
  background: #b7f2d7;
  color: #064e3b;
  }
</style>

<div class="full-screen-map-page">
  <div class="map-overlay-header">
    <%= link_to "← Back to Main", main_path, class: "back-to-main-btn" %>
    
    <div class="overlay-content">
      <div class="overlay-title">CUHK Facilities Booking</div>
      <div class="search-container">
        <input type="text" id="venue-search" placeholder="Search venue..."> 
        <button id="search-btn">Search</button>
      </div>
    </div>

    <% if current_user %>
      <div class="user-info-row">
        <span class="user-display-name"><%= current_user.name %></span>
        <%= link_to "Log out", root_path, data: { turbo_method: :delete }, class: "logout-link" %>
      </div>
    <% end %>
  </div>

  <div id="map"></div>
</div>

<script>
  function initMap() {
    const map = new google.maps.Map(document.getElementById("map"), {
      center: { lat: 22.4198, lng: 114.2068 },
      zoom: 17,
      minZoom: 10,
      gestureHandling: "greedy",
      keyboardShortcuts: false,
      restriction: {
        latLngBounds: {
          north: 22.426270185242515,
          south: 22.378103347356834,
          west: 114.19634845851412,
          east: 114.21840119825353
        },
        strictBounds: false,
      },
    });

    const locations = <%= raw(@map_locations.to_json) %>;

    const infoWindow = new google.maps.InfoWindow();
    const markers = [];

    locations.forEach(location => {
      const marker = new google.maps.Marker({
        position: { lat: location.lat, lng: location.lng },
        map: map,
        title: location.title,
      });

      marker.customData = location;
      markers.push(marker);

      marker.addListener("click", () => {
        openInfoWindow(marker);
      });
    });

    function openInfoWindow(marker) {
      const data = marker.customData;
      const contentString = `
        <div style="padding: 5px; width: 200px;">
          ${data.image_url ? `<img src="${data.image_url}" style="width:100%; height:auto; border-radius:8px; margin-bottom:8px;">` : ''}
          <div style="font-weight: bold; font-size: 14px;">${data.title}</div>
          <div style="font-size: 12px; margin: 4px 0 8px; color: #374151;">Venues: ${data.venue_count}</div>
          <a href="/buildings/${data.slug}" style="color: #4285F4; text-decoration: none; font-size: 12px; font-weight: bold;">Go to page →</a>
        </div>
      `;
      infoWindow.setContent(contentString);
      infoWindow.open(map, marker);
    }

    const searchInput = document.getElementById("venue-search");
    const searchBtn = document.getElementById("search-btn");

    function performSearch() {
      const query = searchInput.value.toLowerCase().trim();
      if (!query) return;

      const match = markers.find(m => m.title.toLowerCase().includes(query));

      if (match) {
        map.setZoom(17);
        map.panTo(match.getPosition());
        openInfoWindow(match);
      } else {
        alert("Venue not found.");
      }
    }

    searchBtn.addEventListener("click", performSearch);
    searchInput.addEventListener("keypress", (e) => {
      if (e.key === "Enter") performSearch();
    });
  }
</script>

<script
  src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.application.credentials.google_maps_api_key %>&callback=initMap"
  defer>
</script>
