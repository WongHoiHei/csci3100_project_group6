%h1 Change Password
= form_with url: password_path, method: :patch, local: true do
  = password_field_tag :old_password, nil, placeholder: 'Old Password'
  = password_field_tag :password, nil, placeholder: 'New Password'
  = password_field_tag :password_confirmation, nil, placeholder: 'Confirm Password'
  = submit_tag 'Update Password'