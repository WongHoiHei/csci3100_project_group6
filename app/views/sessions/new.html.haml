%h1 Login

- if flash[:alert]
  .alert= flash[:alert]

= form_with url: login_path, local: true do |form|
  .field
    = form.label :email
    = form.email_field :email, value: params[:email], placeholder: 'Email'
  
  .field
    = form.label :password
    = form.password_field :password, placeholder: 'Password'
  
  .actions
    = form.submit 'Log in'

%p
  Don't have an account?
  = link_to 'Sign up', signup_path