<h1>Booking Dashboard</h1>

<div class="usage-rate">Utilization: <span id="usage"><%= @stats.usage_rate %>%</span></div>

<canvas id="bookingsChart" width="400" height="200"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  fetch('/dashboards.json')
    .then(r => r.json())
    .then(data => {
      document.getElementById('usage').textContent = data.usage_rate;
      
      new Chart(document.getElementById('bookingsChart'), {
        type: 'line',
        data: {
          labels: Object.keys(data.bookings_data),
          datasets: [{ label: 'Bookings', data: Object.values(data.bookings_data) }]
        }
      });
    });
</script>