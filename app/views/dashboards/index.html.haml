-# This loads Tailwind ONLY for this specific view
%script{ src: "https://cdn.tailwindcss.com" }

.min-h-screen.bg-slate-50.p-8{ data: { controller: "dashboard", dashboard_url_value: dashboards_path } }
  .max-w-7xl.mx-auto
    -# Header
    .flex.justify-between.items-center.mb-10
      %div
        %h1.text-4xl.font-black.text-slate-900 Resource Usage
        %p.text-slate-500.mt-1 Real-time analytics for your department
      
      .flex.items-center.gap-4.bg-white.p-2.rounded-xl.shadow-sm.border
        %label.font-bold.text-slate-600.ml-2 Dept:
        %select.border-none.focus:ring-0.font-medium.text-blue-600{ data: { action: "change->dashboard#update" }, name: "tenant_id" }
          - @tenants.each do |t|
            %option{ value: t.id }= t.name

    -# Search & Sort
    .grid.grid-cols-1.md:grid-cols-3.gap-4.mb-10
      .md:col-span-2.relative
        .absolute.inset-y-0.left-0.pl-3.flex.items-center.pointer-events-none
          %svg.h-5.w-5.text-slate-400{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
            %path{ d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z", "stroke-linecap": "round", "stroke-linejoin": "round", "stroke-width": "2" }
        %input.w-full.border-slate-200.rounded-xl.p-3.pl-10.shadow-sm.focus:ring-2.focus:ring-blue-500{ type: "text", placeholder: "Search...", data: { action: "input->dashboard#applyFilters" }, name: "query" }
      
      %select.w-full.border-slate-200.rounded-xl.p-3.shadow-sm{ data: { action: "change->dashboard#applyFilters" }, name: "sort" }
        %option{ value: "usage_desc" } Most Used
        %option{ value: "name_asc" } Name (A-Z)

    -# Charts Row
    .grid.grid-cols-1.lg:grid-cols-2.gap-8.mb-10
      .bg-white.p-6.rounded-2xl.shadow-sm.border.border-slate-200
        %h2.text-lg.font-bold.mb-4 Venues
        %canvas{ data: { dashboard_target: "venueChart" } }
      
      .bg-white.p-6.rounded-2xl.shadow-sm.border.border-slate-200
        %h2.text-lg.font-bold.mb-4 Equipment
        %canvas{ data: { dashboard_target: "equipmentChart" } }

    -# Tables Row
    .grid.grid-cols-1.lg:grid-cols-2.gap-8
      .bg-white.rounded-2xl.shadow-sm.border.overflow-hidden
        %table.w-full
          %thead.bg-slate-50
            %tr
              %th.p-4.text-left.text-xs.font-bold.text-slate-500 Venue
              %th.p-4.text-right.text-xs.font-bold.text-slate-500 Count
          %tbody.divide-y.divide-slate-100{ data: { dashboard_target: "venueList" } }
      
      .bg-white.rounded-2xl.shadow-sm.border.overflow-hidden
        %table.w-full
          %thead.bg-slate-50
            %tr
              %th.p-4.text-left.text-xs.font-bold.text-slate-500 Equipment
              %th.p-4.text-right.text-xs.font-bold.text-slate-500 Usage
          %tbody.divide-y.divide-slate-100{ data: { dashboard_target: "equipmentList" } }