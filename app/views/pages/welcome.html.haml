.hero-section
  .container.mx-auto.px-6.py-20
    .max-w-md.mx-auto.text-center.space-y-8
      %h1.text-5xl.font-bold.bg-gradient-to-r.from-blue-600.to-purple-600.bg-clip-text.text-transparent.mb-6
        Welcome
      %p.text-xl.text-gray-600.leading-relaxed.max-w-lg.mx-auto
        Please log in to continue.
      = link_to 'Go to Login', login_path, class: 'inline-block bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-bold py-4 px-12 rounded-2xl text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300'